Package: discoCVI
Type: Package
Title: Implementation of the DISCO Metric for Internal Clustering Evaluation
Version: 0.1.0
Authors@R: c(
    person("Amin", "Entezari",
           email   = "amin_entezari@outlook.com",
           role    = c("aut", "cre"),
           comment = c(ORCID = "")),
    person("Davide", "Chicco",
